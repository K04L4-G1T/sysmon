  <!--
  ==================================================================================
  SYSMON CONFIG — WINDOWS 11 HARDENED
  ==================================================================================
  Base:     SwiftOnSecurity (github.com/SwiftOnSecurity/sysmon-config)
  Enhanced: Full C2, Process Injection, Persistence, Exfiltration, LOLBIN coverage
  MITRE:    ATT&CK aligned (T-codes referenced per section)
  Target:   Windows 11 (22H2/23H2/24H2) — single machine / personal SOC
  Schema:   4.90 (Sysmon v15+)
  ==================================================================================

  INSTALL:
    sysmon64.exe -accepteula -i sysmon-config-win11.xml

  UPDATE:
    sysmon64.exe -c sysmon-config-win11.xml

  UNINSTALL:
    sysmon64.exe -u force

  SEND TO ELASTIC (Winlogbeat channel):
    Microsoft-Windows-Sysmon/Operational
  ==================================================================================
  -->

  <!-- Hash everything. SHA256 for threat intel. IMPHASH for malware family grouping. -->
  <HashAlgorithms>MD5,SHA256,IMPHASH</HashAlgorithms>

  <!-- Check driver cert revocation — catches rootkit/malicious driver loads -->
  <CheckRevocation>True</CheckRevocation>

  <!-- DNS lookup enrichment for network events -->
  <DnsLookup>True</DnsLookup>

  <EventFiltering>

    <!-- ============================================================
         EVENT 1 — PROCESS CREATION
         ATT&CK: T1059, T1106, T1055, T1569, T1204
         Captures: ALL processes. Excludes known-clean noise.
         Focus: LOLBins, suspicious parents, encoded commands,
                unusual spawn chains, AppData/Temp execution
         ============================================================ -->
    <RuleGroup name="ProcessCreate" groupRelation="or">
      <ProcessCreate onmatch="exclude">

        <!-- Windows core system noise — stable, low-risk -->
        <Image condition="is">C:\Windows\System32\conhost.exe</Image>
        <Image condition="is">C:\Windows\System32\WerFault.exe</Image>
        <Image condition="is">C:\Windows\System32\wermgr.exe</Image>
        <Image condition="is">C:\Windows\System32\backgroundTaskHost.exe</Image>
        <Image condition="is">C:\Windows\System32\SearchProtocolHost.exe</Image>
        <Image condition="is">C:\Windows\System32\SearchFilterHost.exe</Image>

        <!-- Defender / Security Health — very noisy, low signal -->
        <Image condition="begin with">C:\ProgramData\Microsoft\Windows Defender\</Image>
        <Image condition="begin with">C:\Program Files\Windows Defender\</Image>
        <Image condition="begin with">C:\Program Files\Windows Defender Advanced Threat Protection\</Image>

        <!-- Windows Update stack — high volume, low risk -->
        <Image condition="is">C:\Windows\System32\UsoClient.exe</Image>
        <Image condition="is">C:\Windows\System32\wuauclt.exe</Image>
        <Image condition="begin with">C:\Windows\SoftwareDistribution\</Image>

        <!-- Font cache and rendering — benign -->
        <Image condition="is">C:\Windows\System32\fontdrvhost.exe</Image>
        <Image condition="is">C:\Windows\System32\dwm.exe</Image>

        <!-- Windows 11 — Start Menu / Widgets / Shell -->
        <Image condition="is">C:\Windows\SystemApps\Microsoft.Windows.StartMenuExperienceHost_cw5n1h2txyewy\StartMenuExperienceHost.exe</Image>
        <Image condition="begin with">C:\Windows\SystemApps\MicrosoftWindows.Client.CBS_</Image>

        <!-- System-installed Chrome (per-machine) — adjust if user-installed -->
        <!-- USER-INSTALLED PATH: C:\Users\%USERNAME%\AppData\Local\Google\Chrome\Application\chrome.exe -->
        <Image condition="is">C:\Program Files\Google\Chrome\Application\chrome.exe</Image>
        <Image condition="is">C:\Program Files (x86)\Google\Chrome\Application\chrome.exe</Image>

        <!-- Microsoft Edge (system-installed) -->
        <Image condition="begin with">C:\Program Files (x86)\Microsoft\Edge\Application\</Image>
        <Image condition="begin with">C:\Program Files\Microsoft\Edge\Application\</Image>

        <!-- OneDrive (system-installed) -->
        <Image condition="is">C:\Program Files\Microsoft OneDrive\OneDrive.exe</Image>

        <!-- Teams (new system-installed path Win11) -->
        <Image condition="begin with">C:\Program Files\WindowsApps\MSTeams_</Image>

        <!-- Visual Studio / VSCode — developer noise -->
        <ParentImage condition="is">C:\Program Files\Microsoft VS Code\Code.exe</ParentImage>
        <ParentImage condition="begin with">C:\Program Files\Microsoft Visual Studio\</ParentImage>

      </ProcessCreate>
    </RuleGroup>

    <!-- ============================================================
         EVENT 2 — FILE CREATION TIME CHANGED (Timestomping)
         ATT&CK: T1070.006
         Captures: Attackers modifying file timestamps to evade forensics
         ============================================================ -->
    <RuleGroup name="FileCreateTime" groupRelation="or">
      <FileCreateTime onmatch="exclude">
        <!-- Installers legitimately touch timestamps -->
        <Image condition="is">C:\Windows\System32\msiexec.exe</Image>
        <Image condition="begin with">C:\Windows\System32\svchost.exe</Image>
      </FileCreateTime>
    </RuleGroup>

    <!-- ============================================================
         EVENT 3 — NETWORK CONNECTION
         ATT&CK: T1071, T1095, T1041, T1571, T1090
         Focus: Processes that should NEVER make outbound connections,
                suspicious ports, C2 beaconing indicators
         ============================================================ -->
    <RuleGroup name="NetworkConnect" groupRelation="or">
      <NetworkConnect onmatch="include">

        <!-- CRITICAL: These processes making network connections = high suspicion -->
        <!-- T1059.001 — PowerShell C2 -->
        <Image condition="is">C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe</Image>
        <Image condition="is">C:\Windows\SysWOW64\WindowsPowerShell\v1.0\powershell.exe</Image>
        <Image condition="is">C:\Windows\System32\pwsh.exe</Image>

        <!-- T1059.003 — CMD -->
        <Image condition="is">C:\Windows\System32\cmd.exe</Image>

        <!-- T1218 — LOLBins going outbound -->
        <Image condition="is">C:\Windows\System32\mshta.exe</Image>
        <Image condition="is">C:\Windows\System32\wscript.exe</Image>
        <Image condition="is">C:\Windows\System32\cscript.exe</Image>
        <Image condition="is">C:\Windows\System32\regsvr32.exe</Image>
        <Image condition="is">C:\Windows\System32\rundll32.exe</Image>
        <Image condition="is">C:\Windows\System32\certutil.exe</Image>
        <Image condition="is">C:\Windows\System32\certreq.exe</Image>
        <Image condition="is">C:\Windows\System32\bitsadmin.exe</Image>
        <Image condition="is">C:\Windows\System32\msiexec.exe</Image>
        <Image condition="is">C:\Windows\System32\installutil.exe</Image>
        <Image condition="is">C:\Windows\System32\msbuild.exe</Image>
        <Image condition="is">C:\Windows\System32\cmstp.exe</Image>
        <Image condition="is">C:\Windows\System32\eudcedit.exe</Image>
        <Image condition="is">C:\Windows\System32\wmic.exe</Image>
        <Image condition="is">C:\Windows\System32\finger.exe</Image>

        <!-- T1055 — Injected processes making outbound connections -->
        <!-- explorer.exe phoning home = major C2 indicator -->
        <Image condition="is">C:\Windows\explorer.exe</Image>
        <Image condition="is">C:\Windows\System32\svchost.exe</Image>

        <!-- Suspicious port usage — non-standard C2 -->
        <DestinationPort condition="is">4444</DestinationPort>
        <DestinationPort condition="is">1337</DestinationPort>
        <DestinationPort condition="is">8080</DestinationPort>
        <DestinationPort condition="is">8443</DestinationPort>
        <DestinationPort condition="is">8888</DestinationPort>
        <DestinationPort condition="is">9001</DestinationPort>
        <DestinationPort condition="is">9090</DestinationPort>

      </NetworkConnect>
    </RuleGroup>

    <!-- ============================================================
         EVENT 5 — PROCESS TERMINATED
         Low noise. Track termination of security tools (T1562.001)
         ============================================================ -->
    <RuleGroup name="ProcessTerminate" groupRelation="or">
      <ProcessTerminate onmatch="include">
        <!-- Alert if Sysmon itself is killed -->
        <Image condition="is">C:\Windows\Sysmon64.exe</Image>
        <Image condition="is">C:\Windows\Sysmon.exe</Image>
        <!-- Defender termination — defense evasion -->
        <Image condition="begin with">C:\Program Files\Windows Defender\</Image>
      </ProcessTerminate>
    </RuleGroup>

    <!-- ============================================================
         EVENT 6 — DRIVER LOADED
         ATT&CK: T1014, T1543.003, T1068
         Focus: Unsigned or revoked drivers = rootkit / BYOVD attack
         ============================================================ -->
    <RuleGroup name="DriverLoad" groupRelation="or">
      <DriverLoad onmatch="exclude">
        <!-- Only exclude fully signed Microsoft drivers -->
        <Signature condition="contains">Microsoft</Signature>
        <Signature condition="contains">Windows</Signature>
      </DriverLoad>
    </RuleGroup>

    <!-- ============================================================
         EVENT 7 — IMAGE (DLL) LOADED
         ATT&CK: T1055.001, T1574.001, T1574.002
         Focus: Unsigned DLLs, DLLs from user/temp paths,
                known-bad DLL names used in hijacking
         NOTE: High volume — targeted includes only
         ============================================================ -->
    <RuleGroup name="ImageLoad" groupRelation="or">
      <ImageLoad onmatch="include">

        <!-- DLL loaded from user-writable locations = DLL hijack / drop -->
        <ImageLoaded condition="begin with">C:\Users\</ImageLoaded>
        <ImageLoaded condition="begin with">C:\ProgramData\</ImageLoaded>
        <ImageLoaded condition="begin with">C:\Temp\</ImageLoaded>
        <ImageLoaded condition="begin with">C:\Windows\Temp\</ImageLoaded>

        <!-- DLL loaded from network share -->
        <ImageLoaded condition="begin with">\\</ImageLoaded>

        <!-- Known DLL hijacking targets — T1574.001 -->
        <ImageLoaded condition="end with">version.dll</ImageLoaded>
        <ImageLoaded condition="end with">wtsapi32.dll</ImageLoaded>
        <ImageLoaded condition="end with">cryptsp.dll</ImageLoaded>
        <ImageLoaded condition="end with">cryptbase.dll</ImageLoaded>
        <ImageLoaded condition="end with">dwmapi.dll</ImageLoaded>
        <ImageLoaded condition="end with">WINMM.dll</ImageLoaded>
        <ImageLoaded condition="end with">amsi.dll</ImageLoaded>

        <!-- Unsigned DLL loaded into critical processes -->
        <Signed condition="is">false</Signed>

      </ImageLoad>
    </RuleGroup>

    <!-- ============================================================
         EVENT 8 — CREATE REMOTE THREAD
         ATT&CK: T1055.003, T1055.001, T1055.002
         This event is YOUR PRIMARY INJECTION DETECTOR.
         Classic shellcode injection uses CreateRemoteThread.
         Log EVERYTHING except well-known benign pairs.
         ============================================================ -->
    <RuleGroup name="CreateRemoteThread" groupRelation="or">
      <CreateRemoteThread onmatch="exclude">

        <!-- Known-benign: AV/EDR products legitimately inject -->
        <SourceImage condition="begin with">C:\Program Files\Windows Defender\</SourceImage>
        <SourceImage condition="begin with">C:\ProgramData\Microsoft\Windows Defender\</SourceImage>

        <!-- Windows accessibility framework -->
        <SourceImage condition="is">C:\Windows\System32\csrss.exe</SourceImage>

        <!-- WMI provider host — legitimate COM injection -->
        <SourceImage condition="is">C:\Windows\System32\wbem\WmiPrvSE.exe</SourceImage>

      </CreateRemoteThread>
    </RuleGroup>

    <!-- ============================================================
         EVENT 10 — PROCESS ACCESS (OpenProcess)
         ATT&CK: T1055, T1003.001 (LSASS dump), T1134
         Focus: Suspicious access to LSASS (credential dumping),
                cross-process memory read/write (injection precursor)
         ============================================================ -->
    <RuleGroup name="ProcessAccess" groupRelation="or">
      <ProcessAccess onmatch="include">

        <!-- LSASS access = credential dumping (Mimikatz, etc.) T1003.001 -->
        <TargetImage condition="is">C:\Windows\System32\lsass.exe</TargetImage>

        <!-- Suspicious access rights mask — PROCESS_VM_READ | PROCESS_VM_WRITE -->
        <GrantedAccess condition="is">0x1010</GrantedAccess>
        <GrantedAccess condition="is">0x1fffff</GrantedAccess>
        <GrantedAccess condition="is">0x1f0fff</GrantedAccess>
        <GrantedAccess condition="is">0x143a</GrantedAccess>
        <GrantedAccess condition="is">0x40</GrantedAccess>
        <GrantedAccess condition="is">0x1000</GrantedAccess>

        <!-- Accessing other browsers for credential theft -->
        <TargetImage condition="end with">chrome.exe</TargetImage>
        <TargetImage condition="end with">firefox.exe</TargetImage>
        <TargetImage condition="end with">msedge.exe</TargetImage>

        <!-- Accessing security tools — T1562 defense evasion -->
        <TargetImage condition="begin with">C:\Program Files\Windows Defender\</TargetImage>

      </ProcessAccess>
    </RuleGroup>

    <!-- ============================================================
         EVENT 11 — FILE CREATED
         ATT&CK: T1105, T1027, T1036, T1204
         Focus: Executables/scripts dropped in suspicious locations,
                C2 payload staging paths
         ============================================================ -->
    <RuleGroup name="FileCreate" groupRelation="or">
      <FileCreate onmatch="include">

        <!-- Executables/scripts dropped anywhere suspicious -->
        <TargetFilename condition="end with">.exe</TargetFilename>
        <TargetFilename condition="end with">.dll</TargetFilename>
        <TargetFilename condition="end with">.bat</TargetFilename>
        <TargetFilename condition="end with">.ps1</TargetFilename>
        <TargetFilename condition="end with">.vbs</TargetFilename>
        <TargetFilename condition="end with">.js</TargetFilename>
        <TargetFilename condition="end with">.hta</TargetFilename>
        <TargetFilename condition="end with">.msi</TargetFilename>
        <TargetFilename condition="end with">.cmd</TargetFilename>
        <TargetFilename condition="end with">.scr</TargetFilename>
        <TargetFilename condition="end with">.lnk</TargetFilename>
        <TargetFilename condition="end with">.cpl</TargetFilename>
        <TargetFilename condition="end with">.xll</TargetFilename>

        <!-- Files created in temp/staging paths -->
        <TargetFilename condition="begin with">C:\Temp\</TargetFilename>
        <TargetFilename condition="begin with">C:\Windows\Temp\</TargetFilename>
        <TargetFilename condition="begin with">C:\Users\Public\</TargetFilename>
        <TargetFilename condition="begin with">C:\ProgramData\</TargetFilename>

        <!-- Startup / persistence folders -->
        <TargetFilename condition="contains">Startup</TargetFilename>
        <TargetFilename condition="contains">Start Menu\Programs\Startup</TargetFilename>

        <!-- Windows 11 specific — WindowsApps writable staging -->
        <TargetFilename condition="begin with">C:\Users\</TargetFilename>

      </FileCreate>
    </RuleGroup>

    <!-- ============================================================
         EVENT 12 / 13 / 14 — REGISTRY EVENTS
         ATT&CK: T1547.001, T1546, T1112, T1574.011
         Focus: Persistence keys, Run/RunOnce, services,
                COM hijacking, AppInit_DLLs
         ============================================================ -->
    <RuleGroup name="RegistryEvent" groupRelation="or">
      <RegistryEvent onmatch="include">

        <!-- Run/RunOnce — classic persistence T1547.001 -->
        <TargetObject condition="contains">SOFTWARE\Microsoft\Windows\CurrentVersion\Run</TargetObject>
        <TargetObject condition="contains">SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce</TargetObject>
        <TargetObject condition="contains">SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Run</TargetObject>

        <!-- Services — T1543.003 -->
        <TargetObject condition="begin with">HKLM\System\CurrentControlSet\Services</TargetObject>

        <!-- AppInit_DLLs — DLL injection via registry T1546.010 -->
        <TargetObject condition="contains">AppInit_DLLs</TargetObject>

        <!-- COM hijacking — T1546.015 -->
        <TargetObject condition="contains">HKCU\SOFTWARE\Classes\CLSID</TargetObject>
        <TargetObject condition="contains">InProcServer32</TargetObject>

        <!-- Boot/logon autostart -->
        <TargetObject condition="contains">CurrentVersion\Winlogon</TargetObject>
        <TargetObject condition="contains">CurrentVersion\Authentication\Credential Providers</TargetObject>

        <!-- LSA — credential provider / SSP injection T1547.005 -->
        <TargetObject condition="contains">SYSTEM\CurrentControlSet\Control\Lsa</TargetObject>

        <!-- Image File Execution Options — debugger hijack T1546.012 -->
        <TargetObject condition="contains">SOFTWARE\Microsoft\Windows NT\CurrentVersion\Image File Execution Options</TargetObject>

        <!-- Disable Windows Defender via registry — T1562.001 -->
        <TargetObject condition="contains">Windows Defender\DisableAntiSpyware</TargetObject>
        <TargetObject condition="contains">Windows Defender\DisableRealtimeMonitoring</TargetObject>

        <!-- PowerShell policy weakening -->
        <TargetObject condition="contains">SOFTWARE\Policies\Microsoft\Windows\PowerShell</TargetObject>

        <!-- Scheduled tasks registry -->
        <TargetObject condition="begin with">HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Schedule\TaskCache</TargetObject>

        <!-- Sysmon config tampering detection -->
        <TargetObject condition="begin with">HKLM\SYSTEM\CurrentControlSet\Services\SysmonDrv</TargetObject>

      </RegistryEvent>
    </RuleGroup>

    <!-- ============================================================
         EVENT 15 — FILE STREAM CREATED (Alternate Data Streams)
         ATT&CK: T1564.004
         Focus: ADS used to hide payloads inside legitimate files
         ============================================================ -->
    <RuleGroup name="FileCreateStreamHash" groupRelation="or">
      <FileCreateStreamHash onmatch="exclude">
        <!-- Browser downloads legitimately create Zone.Identifier ADS -->
        <Contents condition="contains">ZoneTransfer</Contents>
      </FileCreateStreamHash>
    </RuleGroup>

    <!-- ============================================================
         EVENT 17 / 18 — PIPE CREATED / CONNECTED
         ATT&CK: T1021.002, T1570, T1559.001
         Focus: Cobalt Strike default pipe names, lateral movement,
                named pipe impersonation
         ============================================================ -->
    <RuleGroup name="PipeEvent" groupRelation="or">
      <PipeEvent onmatch="include">

        <!-- Cobalt Strike default + common variant pipe names -->
        <PipeName condition="begin with">\mojo.</PipeName>
        <PipeName condition="begin with">\msagent_</PipeName>
        <PipeName condition="begin with">\DserNamePipe</PipeName>
        <PipeName condition="begin with">\mypipe-</PipeName>
        <PipeName condition="begin with">\f4c3</PipeName>
        <PipeName condition="begin with">\fullduplex_</PipeName>
        <PipeName condition="begin with">\rpc_</PipeName>
        <PipeName condition="begin with">\spoolss_</PipeName>
        <PipeName condition="begin with">\Posh</PipeName>
        <PipeName condition="begin with">\postex_</PipeName>
        <PipeName condition="begin with">\status_</PipeName>
        <PipeName condition="contains">MSSE-</PipeName>
        <PipeName condition="contains">windows_shell</PipeName>
        <PipeName condition="begin with">\ntsvcs</PipeName>
        <PipeName condition="begin with">\scerpc</PipeName>

        <!-- Sliver C2 pipes -->
        <PipeName condition="contains">svcctl</PipeName>

        <!-- Metasploit pipes -->
        <PipeName condition="begin with">\PSHost</PipeName>

      </PipeEvent>
    </RuleGroup>

    <!-- ============================================================
         EVENT 19 / 20 / 21 — WMI EVENTS
         ATT&CK: T1047, T1546.003
         Focus: WMI persistence subscriptions, WMI C2, lateral movement
         Fileless attackers LOVE WMI — log everything.
         ============================================================ -->
    <RuleGroup name="WmiEvent" groupRelation="or">
      <WmiEvent onmatch="exclude">
        <!-- Nothing excluded — WMI abuse is too dangerous to filter -->
      </WmiEvent>
    </RuleGroup>

    <!-- ============================================================
         EVENT 22 — DNS QUERY
         ATT&CK: T1071.004, T1568, T1008
         Focus: C2 domains, DGA patterns, DNS tunneling,
                suspicious TLDs, encoded subdomains
         NOTE: This is noisy. Deploy browser-level ad blocking
               (uBlock Origin) to reduce volume significantly.
         ============================================================ -->
    <RuleGroup name="DnsQuery" groupRelation="or">
      <DnsQuery onmatch="exclude">

        <!-- Microsoft services — high volume, low risk -->
        <QueryName condition="end with">.microsoft.com</QueryName>
        <QueryName condition="end with">.windows.com</QueryName>
        <QueryName condition="end with">.windowsupdate.com</QueryName>
        <QueryName condition="end with">.msftconnecttest.com</QueryName>
        <QueryName condition="end with">.msedge.net</QueryName>
        <QueryName condition="end with">.live.com</QueryName>
        <QueryName condition="end with">.office.com</QueryName>
        <QueryName condition="end with">.office365.com</QueryName>
        <QueryName condition="end with">.azure.com</QueryName>
        <QueryName condition="end with">.azurefd.net</QueryName>
        <QueryName condition="end with">.microsoftonline.com</QueryName>

        <!-- CDNs / major platforms -->
        <QueryName condition="end with">.cloudflare.com</QueryName>
        <QueryName condition="end with">.akamai.net</QueryName>
        <QueryName condition="end with">.akamaied.net</QueryName>
        <QueryName condition="end with">.amazonaws.com</QueryName>
        <QueryName condition="end with">.googleapis.com</QueryName>
        <QueryName condition="end with">.gstatic.com</QueryName>
        <QueryName condition="end with">.google.com</QueryName>
        <QueryName condition="end with">.googlevideo.com</QueryName>
        <QueryName condition="end with">.youtube.com</QueryName>
        <QueryName condition="end with">.github.com</QueryName>
        <QueryName condition="end with">.github.io</QueryName>

      </DnsQuery>
    </RuleGroup>

    <!-- ============================================================
         EVENT 23 — FILE DELETED
         ATT&CK: T1070.004, T1485
         Focus: Ransomware deletion patterns, log clearing,
                evidence cleanup after intrusion
         ============================================================ -->
    <RuleGroup name="FileDelete" groupRelation="or">
      <FileDelete onmatch="include">

        <!-- Deletion of Windows event logs — T1070.001 -->
        <TargetFilename condition="end with">.evtx</TargetFilename>

        <!-- Deletion of shadow copies / backups — T1490 ransomware -->
        <TargetFilename condition="contains">Shadow Copy</TargetFilename>
        <TargetFilename condition="end with">.vhd</TargetFilename>
        <TargetFilename condition="end with">.vhdx</TargetFilename>
        <TargetFilename condition="end with">.bak</TargetFilename>

        <!-- Sysmon / security tool deletion -->
        <TargetFilename condition="contains">sysmon</TargetFilename>

        <!-- Script/payload cleanup after execution -->
        <TargetFilename condition="end with">.ps1</TargetFilename>
        <TargetFilename condition="end with">.vbs</TargetFilename>
        <TargetFilename condition="end with">.bat</TargetFilename>

      </FileDelete>
    </RuleGroup>

    <!-- ============================================================
         EVENT 25 — PROCESS TAMPERING
         ATT&CK: T1055.012 (Process Hollowing), T1055.013 (Herpaderping)
         This event catches process hollowing and process herpaderping
         — two of the most dangerous evasion techniques.
         Log ALL. No exclusions.
         ============================================================ -->
    <RuleGroup name="ProcessTampering" groupRelation="or">
      <ProcessTampering onmatch="include">
        <Image condition="begin with">C:\</Image>
      </ProcessTampering>
    </RuleGroup>

    <!-- ============================================================
         EVENT 26 — FILE DELETE LOGGED (with archive)
         Logs files deleted by monitored processes — kept for forensics
         Focus: Malware cleaning up after itself
         ============================================================ -->
    <RuleGroup name="FileDeleteDetected" groupRelation="or">
      <FileDeleteDetected onmatch="include">
        <TargetFilename condition="end with">.exe</TargetFilename>
        <TargetFilename condition="end with">.dll</TargetFilename>
        <TargetFilename condition="end with">.ps1</TargetFilename>
        <TargetFilename condition="end with">.bat</TargetFilename>
      </FileDeleteDetected>
    </RuleGroup>

    <!-- ============================================================
         EVENT 27 — FILE BLOCK EXECUTABLE
         Blocks executable creation in user-writable locations.
         Requires Sysmon v14+ in block mode (optional).
         ============================================================ -->
    <RuleGroup name="FileBlockExecutable" groupRelation="or">
      <FileBlockExecutable onmatch="include">
        <TargetFilename condition="begin with">C:\Users\Public\</TargetFilename>
        <TargetFilename condition="begin with">C:\Temp\</TargetFilename>
        <TargetFilename condition="begin with">C:\Windows\Temp\</TargetFilename>
        <TargetFilename condition="begin with">C:\ProgramData\</TargetFilename>
      </FileBlockExecutable>
    </RuleGroup>

    <!-- ============================================================
         EVENT 29 — FILE EXECUTABLE DETECTED
         ATT&CK: T1105 (Ingress Tool Transfer), T1204
         Sysmon v15+ — detects new PE files appearing on disk
         Focus: Payload drops into staging paths
         ============================================================ -->
    <RuleGroup name="FileExecutableDetected" groupRelation="or">
      <FileExecutableDetected onmatch="include">
        <TargetFilename condition="begin with">C:\Users\</TargetFilename>
        <TargetFilename condition="begin with">C:\ProgramData\</TargetFilename>
        <TargetFilename condition="begin with">C:\Temp\</TargetFilename>
        <TargetFilename condition="begin with">C:\Windows\Temp\</TargetFilename>
        <TargetFilename condition="begin with">C:\Users\Public\</TargetFilename>
      </FileExecutableDetected>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
